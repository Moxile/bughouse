{
  "name": "bughouse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "client",
    "shared"
  ],
  "scripts": {
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "test": "npm --workspace server test",
    "build": "npm --workspace shared run build && npm --workspace client run build && npm --workspace server run build",
    "start": "npm --workspace server run start"
  }
}
